{
    "version": 2,
    "builds": [
        {
            "src": "backend/app.ts",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": { "distDir": "dist" }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "backend/app.ts"
        },
        {
            "source": "/(.*)",
            "destination": "frontend/$1"
        }
    ]
}
